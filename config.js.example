// Tango Vocab — 파일 기반 설정 (선택)
//
// index.html에 기본 Apps Script URL이 내장돼 있어서 보통 이 파일은 필요 없습니다.
// 다른 시트(다른 Apps Script 배포)를 연결할 때만 사용하세요.
//
// 사용법:
//   1) 이 파일을 config.js 로 복사  ->  cp config.js.example config.js
//   2) gasUrl 을 채우기
//   3) config.js 는 .gitignore 처리되어 깃에 올라가지 않음
//
// 읽기·쓰기 모두 Apps Script 하나로 처리합니다. 브라우저에 API 키는 없습니다.
window.TANGO_CONFIG = {
  gasUrl: "https://script.google.com/macros/s/.../exec",
};
